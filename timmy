# ─── Pick random art ──────────────────────────────────────────────────────────
ARTS=("$ART1" "$ART2" "$ART3")
ART="${ARTS[$((RANDOM % 3))]}"

# ─── Random TIMMAAAY yell ─────────────────────────────────────────────────────
YELLS=(
    "TIMMAY!"
    "TIMMAAAY!"
    "TIIIMMMAAAAYYY!"
    "T I M M A A A A A Y ! ! !"
    "TIMMY TIMMY TIMMY TIMMAY!"
    "TIIIIIMMMMMMAAAAAAAAYYYY!!!!"
)
YELL="${YELLS[$((RANDOM % ${#YELLS[@]}))]}"

# ─── ANSI colors ─────────────────────────────────────────────────────────────
ORANGE='\033[38;5;208m'   # hair
RED='\033[38;5;196m'      # shirt / banner
TEAL='\033[38;5;37m'      # footrest / wheels
BROWN='\033[38;5;94m'     # wheelchair frame
WHITE='\033[97m'          # face / eyes
BOLD='\033[1m'
RESET='\033[0m'

# Color is on by default; disable with --no-color or if not a TTY
USE_COLOR=1
[[ "${1}" == "--no-color" ]] && USE_COLOR=0 && shift
[[ ! -t 1 ]] && USE_COLOR=0   # piped output — strip color

colorize() {
    if [[ $USE_COLOR -eq 0 ]]; then
        cat
        return
    fi
    # Apply color passes:
    # * and # → brown (wheelchair/body)   = and + → teal (footrest/wheels)
    # @ → orange (hair)                   : and . → white (face/background)
    sed \
        -e "s/[@]/$(printf "$ORANGE")&$(printf "$RESET")/g" \
        -e "s/[*#]/$(printf "$BROWN")&$(printf "$RESET")/g" \
        -e "s/[=+]/$(printf "$TEAL")&$(printf "$RESET")/g" \
        -e "s/[-]/$(printf "$WHITE")&$(printf "$RESET")/g"
}

# ─── Print ────────────────────────────────────────────────────────────────────
if [[ $USE_COLOR -eq 1 ]]; then
    printf "${RED}${BOLD}%s${RESET}\n" "$BANNER"
else
    printf '%s\n' "$BANNER"
fi

printf '%s\n' "$ART" | colorize
printf "\n${ORANGE}${BOLD}  >>> %s <<<${RESET}\n\n" "$YELL"

# ─── Exit code passthrough ────────────────────────────────────────────────────
exit "${1:-0}"
