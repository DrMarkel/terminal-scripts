#!/usr/bin/env bash
# stephen — prints Stephen Hawking ASCII art with a quote
# Usage: stephen [exit_code]

QUOTES=(
    "Intelligence is the ability to adapt to change."
    "However difficult life may seem, there is always something you can do and succeed at."
    "Look up at the stars and not down at your feet."
    "We are just an advanced breed of monkeys on a minor planet of a very average star."
    "My goal is simple. It is a complete understanding of the universe."
    "Life would be tragic if it weren't funny."
    "The greatest enemy of knowledge is not ignorance, it is the illusion of knowledge."
    "Remember to look up at the stars and not down at your feet. Try to make sense of what you see."
)

if [ -t 1 ]; then
  CYAN="\033[36m"; BOLD="\033[1m"; RESET="\033[0m"
else
  CYAN=""; BOLD=""; RESET=""
fi

STATE_FILE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/.stephen_state"
LAST=$(cat "$STATE_FILE" 2>/dev/null || echo "3")
NEXT=$(( (LAST % 3) + 1 ))
echo "$NEXT" > "$STATE_FILE"

